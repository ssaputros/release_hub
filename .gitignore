# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.build/
.buildlog/
.history
.svn/
.swiftpm/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Ignore files in icon directory but keep the folder
icon/*
!icon/.gitkeep

# Ignore environment variables
.env

# Ignore files inside build_result but keep the folder
build_result/*
!build_result/.gitkeep

# Ignore files inside credentials but keep the folder
credentials/*
!credentials/.gitkeep

# Ignore files inside tmp but keep the folder
tmp/*
!tmp/.gitkeep
